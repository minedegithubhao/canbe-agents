# FastAPI
APP_NAME=faq-rag-assistant
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
JD_HELP_CLEANED_JSONL_PATH=exports/jd_help_faq.cleaned.jsonl
JD_HELP_CHUNKS_JSONL_PATH=exports/jd_help_faq.chunks.jsonl
JD_HELP_SYNONYMS_PATH=configs/jd_help_synonyms.yaml

# Public FAQ data import
CRAWL_START_URL=https://help.jd.com/user/issue.html
CRAWL_ALLOWED_DOMAIN=help.jd.com
CRAWL_EXACT_URL_ONLY=false
CRAWL_ALLOW_LINK_DISCOVERY=true
CRAWL_MAX_PAGES=120
CRAWL_MAX_CONCURRENCY=1
CRAWL_DELAY_MIN_SECONDS=2
CRAWL_DELAY_MAX_SECONDS=5
CRAWL_MAX_RETRIES=2
CRAWL_USER_AGENT=faq-rag-public-data-import/1.0

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_MODEL=
DEEPSEEK_TIMEOUT_SECONDS=60

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=canbe_faq_rag

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_DATABASE=default
MILVUS_COLLECTION=canbe_faq_rag_vector_index

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX=canbe_faq_rag_search_index

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PREFIX=canbe_faq_rag

# Embedding / reranker provider
# local: use local BGE models; bailian: use Alibaba Cloud Bailian/DashScope API.
EMBEDDING_PROVIDER=bailian
RERANKER_PROVIDER=bailian

# Local models
BGE_M3_MODEL_PATH=models/bge-m3
BGE_RERANKER_MODEL_PATH=models/bge-reranker-base
BGE_M3_DENSE_DIMENSION=1024
ENABLE_RERANKER=true

# Bailian / DashScope models
# Keep BAILIAN_EMBEDDING_DIMENSION consistent with the Milvus collection dimension.
BAILIAN_API_KEY=
# If you already use DashScope naming, DASHSCOPE_API_KEY is also supported.
DASHSCOPE_API_KEY=
BAILIAN_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_EMBEDDING_MODEL=text-embedding-v4
BAILIAN_EMBEDDING_DIMENSION=1024
BAILIAN_EMBEDDING_BATCH_SIZE=10
BAILIAN_EMBEDDING_TIMEOUT_SECONDS=60
BAILIAN_RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1
BAILIAN_RERANK_MODEL=qwen3-rerank
BAILIAN_RERANK_TIMEOUT_SECONDS=60

# Bailian / DashScope models
# Keep BAILIAN_EMBEDDING_DIMENSION consistent with the Milvus collection dimension.
BAILIAN_API_KEY=sk-0798639eb1954d728947a86f36bf39dc
BAILIAN_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_EMBEDDING_MODEL=text-embedding-v4
BAILIAN_EMBEDDING_DIMENSION=1024
BAILIAN_EMBEDDING_BATCH_SIZE=10
BAILIAN_EMBEDDING_TIMEOUT_SECONDS=60
BAILIAN_RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1
BAILIAN_RERANK_MODEL=qwen3-rerank
BAILIAN_RERANK_TIMEOUT_SECONDS=60

# Retrieval
RETRIEVAL_DENSE_TOP_K=20
RETRIEVAL_SPARSE_TOP_K=20
RETRIEVAL_KEYWORD_TOP_K=20
RETRIEVAL_FINAL_TOP_K=5
RETRIEVAL_ENABLE_RRF=true
RETRIEVAL_RRF_K=60
RETRIEVAL_HIGH_CONFIDENCE_THRESHOLD=0.78
RETRIEVAL_MEDIUM_CONFIDENCE_THRESHOLD=0.65
RETRIEVAL_RERANK_CANDIDATE_MULTIPLIER=4
